{
  "name": "seal-quant-light",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @seal-quant/server --filter @seal-quant/web dev",
    "dev:server": "pnpm --filter @seal-quant/server dev",
    "dev:web": "pnpm --filter @seal-quant/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest"
  }
}
